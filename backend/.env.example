DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/ai_academy
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# builtin — встроенный наставник (работает сразу)
# remote — обученная модель из папки ai-model/
AI_PROVIDER=builtin
AI_BASE_URL=http://localhost:8001/v1
AI_MODEL=ai-academy-mentor
AI_API_KEY=
AI_TIMEOUT_SEC=60
CODE_RUNNER_TIMEOUT_SEC=5
